# =============================================================================
# Open Connect - Professional .gitignore
# =============================================================================

# Environment and Secrets
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Supabase Vaults - Never commit these
SUPABASE_URL
SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY
DATABASE_URL
REDIS_URL
OPEN_CONNECT_API_KEY

# IDE specific files
.idea/
.vscode/
*.swp
*.swo
*~

# Build and Distribution
node_modules/
dist/
build/
*.egg-info/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Logs and Databases
*.log
*.sqlite
*.db
*.bak
*.backup

# Docker
docker-compose.override.yml
docker-compose.local.yml
.docker/

# Railway Specific
railway.json
railway.toml.local
railway-start.sh.bak

# Test and Coverage
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes/
ehthumbs.db
Thumbs.db

# Backup Files
*.bak
*.backup
*.orig
*.rej
*~

# Temporary Files
*.tmp
*.temp
.cache/

# Local Configuration Overrides
*.local
*.override

# Notes:
# - All secrets MUST be managed via Railway Variables (Supabase Vaults)
# - Never commit .env files or files containing secrets
# - Railway automatically injects variables from its settings
# - Use .env.example as a template for local development