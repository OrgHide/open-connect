# XStack Open-Connect - Environment Configuration
# Copy this file to .env and fill in your values

# APPLICATION CONFIGURATION
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# DATABASE CONFIGURATION
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xstack
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSL=false

# REDIS CONFIGURATION
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SECURITY CONFIGURATION
JWT_SECRET=your_jwt_secret_here_change_in_production
SESSION_SECRET=your_session_secret_here_change_in_production
API_KEYS_ENABLED=false

# MCP GATEWAY CONFIGURATION
MCP_GATEWAY=mcp://gateway

# SUPABASE CONFIGURATION (Optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
SECRET_STORAGE=memory

# EXTERNAL CONNECTIONS
OPENCLAW_API=https://openclaw.ai/api
OPENCLAW_MCP=mcp://openclaw
SWARMCLAW_API=https://www.swarmclaw.ai/api
SWARMCLAW_MCP=mcp://swarmclaw
SWARMDOCK_API=https://www.swarmdock.ai/api
SWARMDOCK_MCP=mcp://swarmdock
SKILLSLLM_API=https://skillsllm.com/api
SKILLSLLM_MCP=mcp://skillsllm
MULTION_API=https://docs.multion.ai/api
MULTION_MCP=mcp://multion
OMNI_API=https://docs.omni.co/api
OMNI_MCP=mcp://omni
OPENAGENT_API=https://app.open-agent.io/api
OPENAGENT_MCP=mcp://openagent
AGENTFIELD_API=https://agentfield.ai/api
AGENTFIELD_MCP=mcp://agentfield
AGENCYAGENTS_API=https://agencyagents.dev/api
AGENCYAGENTS_MCP=mcp://agencyagents
CLAWHUB_API=https://clawhub.ai/api
CLAWHUB_MCP=mcp://clawhub

# FEATURE FLAGS
FEATURE_ANALYTICS=true
FEATURE_AUDIT_LOGS=true
FEATURE_RATE_LIMITING=true

# LOGGING CONFIGURATION
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=console

# CACHE CONFIGURATION
CACHE_ENABLED=true
CACHE_TTL=300

# RAILWAY SPECIFIC (Auto-injected by Railway)
# RAILWAY_POSTGRES_HOST
# RAILWAY_POSTGRES_PORT
# RAILWAY_POSTGRES_DATABASE
# RAILWAY_POSTGRES_USER
# RAILWAY_POSTGRES_PASSWORD
# RAILWAY_REDIS_HOST
# RAILWAY_REDIS_PORT
# RAILWAY_REDIS_PASSWORD
# RAILWAY_PUBLIC_DOMAIN

# GITHUB ACTIONS SPECIFIC
# RAILWAY_API_KEY
# RAILWAY_PROJECT_ID

# Generate secure secrets with:
# JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
