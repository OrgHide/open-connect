# =============================================================================
# Open Connect - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values
# For Railway deployment, configure these in Railway Variables (Supabase Vaults)
# =============================================================================

# Supabase Configuration (Required)
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Configuration (Required)
DATABASE_URL=postgresql://postgres:[your-password]@[your-host]:5432/postgres

# Redis Configuration (Required)
REDIS_URL=redis://[your-redis-host]:[your-redis-port]/0

# Open Connect Configuration
OPEN_CONNECT_BASE_URL=https://open-connect-production.up.railway.app
OPEN_CONNECT_API_KEY=

# Environment
ENV=prod
DOCKER=true
PORT=8080

# Logging
LOG_LEVEL=info

# Backup configuration
ENABLE_BACKUP_RESTORE_ON_STARTUP=true
SUPABASE_BUCKET=open-connect-backups
BACKUP_PREFIX=backups

# Notes:
# 1. For Railway deployment, DO NOT commit actual values to this file
# 2. Configure all secrets in Railway Variables (Settings > Variables)
# 3. Railway automatically injects these into the container
# 4. Use Supabase Vaults for secure secret management
# 5. All built-in features (Computer, Terminal, Browser) work without additional config